#!/bin/sh

set -eu

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/nvim"
SOCKET="${UNITY_NVIM_SOCKET:-$STATE_DIR/unity.sock}"
NVIM_BIN="${UNITY_NVIM_BIN:-}"
TERMINAL_CMD="${UNITY_NVIM_TERMINAL_CMD:-}"
TERMINAL_APP="${UNITY_NVIM_TERMINAL_APP:-Terminal}"

if [ -z "$NVIM_BIN" ]; then
  NVIM_BIN=$(command -v nvim 2>/dev/null || true)
fi

if [ -z "$NVIM_BIN" ] || [ ! -x "$NVIM_BIN" ]; then
  echo "nvim executable not found. Set UNITY_NVIM_BIN or add nvim to PATH." >&2
  exit 127
fi

mkdir -p "$STATE_DIR"

file=""
line=1
column=1

is_integer() {
  case "$1" in
    ''|*[!0-9]*)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

parse_target() {
  target="$1"

  case "$target" in
    *:[0-9]*:[0-9]*)
      file=${target%:[0-9]*:[0-9]*}
      rest=${target#"$file":}
      line=${rest%%:*}
      column=${rest##*:}
      ;;
    *:[0-9]*)
      file=${target%:[0-9]*}
      line=${target##*:}
      ;;
    *)
      file="$target"
      ;;
  esac
}

launch_new_session() {
  set -- "$NVIM_BIN" --listen "$SOCKET" "$file" "+call cursor(${line}, ${column})"

  if [ -n "$TERMINAL_CMD" ]; then
    # shellcheck disable=SC2086
    exec $TERMINAL_CMD "$@"
  fi

  if command -v ghostty >/dev/null 2>&1; then
    exec ghostty -e "$@"
  fi
  if command -v kitty >/dev/null 2>&1; then
    exec kitty -e "$@"
  fi
  if command -v wezterm >/dev/null 2>&1; then
    exec wezterm start -- "$@"
  fi
  if command -v alacritty >/dev/null 2>&1; then
    exec alacritty -e "$@"
  fi
  if command -v gnome-terminal >/dev/null 2>&1; then
    exec gnome-terminal -- "$@"
  fi
  if command -v konsole >/dev/null 2>&1; then
    exec konsole -e "$@"
  fi
  if command -v x-terminal-emulator >/dev/null 2>&1; then
    exec x-terminal-emulator -e "$@"
  fi
  if command -v xterm >/dev/null 2>&1; then
    exec xterm -e "$@"
  fi

  if [ "$(uname -s)" = "Darwin" ] && command -v open >/dev/null 2>&1; then
    exec open -na "$TERMINAL_APP" --args "$@"
  fi

  echo "No terminal launcher found. Start manually: $NVIM_BIN --listen \"$SOCKET\"" >&2
  exit 127
}

if [ "$#" -lt 1 ]; then
  echo "usage: unity-nvim-open <file> [line] [column]" >&2
  exit 64
fi

parse_target "$1"
shift

if [ "$#" -gt 0 ] && is_integer "$1"; then
  line="$1"
  shift
fi

if [ "$#" -gt 0 ] && is_integer "$1"; then
  column="$1"
fi

if [ -e "$SOCKET" ] && [ ! -S "$SOCKET" ]; then
  rm -f "$SOCKET"
fi

if [ -S "$SOCKET" ]; then
  if "$NVIM_BIN" --server "$SOCKET" --remote "$file" >/dev/null 2>&1; then
    keys="<C-\\><C-N>:call cursor(${line},${column})<CR>zz"
    "$NVIM_BIN" --server "$SOCKET" --remote-send "$keys" >/dev/null 2>&1 || true
    exit 0
  fi

  rm -f "$SOCKET"
fi

launch_new_session
