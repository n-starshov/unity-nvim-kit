{
  "Unity MonoBehaviour Class": {
    "prefix": "umb",
    "body": [
      "using UnityEngine;",
      "",
      "public class ${1:ClassName} : MonoBehaviour",
      "{",
      "\t[SerializeField] private ${2:GameObject} ${3:target};",
      "",
      "\tprivate void Awake()",
      "\t{",
      "\t\t${0}",
      "\t}",
      "",
      "\tprivate void Start()",
      "\t{",
      "\t}",
      "",
      "\tprivate void Update()",
      "\t{",
      "\t}",
      "}"
    ],
    "description": "Unity MonoBehaviour class skeleton"
  },
  "Unity Serialized Field": {
    "prefix": "usf",
    "body": [
      "[SerializeField] private ${1:int} ${2:value};"
    ],
    "description": "Serialized private field"
  },
  "Unity Header + Serialized Field": {
    "prefix": "uhf",
    "body": [
      "[Header(\"${1:Header}\")]",
      "[SerializeField] private ${2:int} ${3:value};"
    ],
    "description": "Header and serialized field"
  },
  "Unity RequireComponent Class": {
    "prefix": "urc",
    "body": [
      "using UnityEngine;",
      "",
      "[RequireComponent(typeof(${1:Rigidbody}))]",
      "public class ${2:ClassName} : MonoBehaviour",
      "{",
      "\tprivate ${1} _${3:component};",
      "",
      "\tprivate void Awake()",
      "\t{",
      "\t\t_${3:component} = GetComponent<${1}>();",
      "\t\t${0}",
      "\t}",
      "}"
    ],
    "description": "Class with RequireComponent and cached component"
  },
  "Unity Singleton MonoBehaviour": {
    "prefix": "usingle",
    "body": [
      "public class ${1:ClassName} : MonoBehaviour",
      "{",
      "\tpublic static ${1:ClassName} Instance { get; private set; }",
      "",
      "\tprivate void Awake()",
      "\t{",
      "\t\tif (Instance != null && Instance != this)",
      "\t\t{",
      "\t\t\tDestroy(gameObject);",
      "\t\t\treturn;",
      "\t\t}",
      "",
      "\t\tInstance = this;",
      "\t\tDontDestroyOnLoad(gameObject);",
      "\t\t${0}",
      "\t}",
      "}"
    ],
    "description": "Simple singleton MonoBehaviour pattern"
  },
  "Unity Coroutine Method": {
    "prefix": "uco",
    "body": [
      "private IEnumerator ${1:RoutineName}()",
      "{",
      "\t${0:yield return null;}",
      "}"
    ],
    "description": "Coroutine method skeleton"
  },
  "Unity Start Coroutine": {
    "prefix": "ustartco",
    "body": [
      "StartCoroutine(${1:RoutineName}());"
    ],
    "description": "Start coroutine call"
  },
  "Unity Stop Coroutine": {
    "prefix": "ustopco",
    "body": [
      "StopCoroutine(${1:RoutineName}());"
    ],
    "description": "Stop coroutine call"
  },
  "Unity TryGetComponent": {
    "prefix": "utryget",
    "body": [
      "if (TryGetComponent<${1:Collider}>(${2:component}))",
      "{",
      "\t${0}",
      "}"
    ],
    "description": "TryGetComponent block"
  },
  "Unity Log": {
    "prefix": "ulog",
    "body": [
      "Debug.Log(\"${1:message}\", this);"
    ],
    "description": "Debug.Log with context"
  },
  "Unity Warning": {
    "prefix": "uwarn",
